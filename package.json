{
  "name": "cobalt-mono-design-system",
  "version": "0.1.0",
  "description": "Cobalt — Mono Design System: monochrome surfaces with a single cobalt accent, Pretendard type (Korean + English), light & dark. 37 React components and a token-driven CSS layer.",
  "type": "module",
  "license": "MIT",
  "author": "Greencar-UXD",
  "homepage": "https://github.com/Greencar-UXD/design-system#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Greencar-UXD/design-system.git"
  },
  "keywords": [
    "design-system",
    "react",
    "css",
    "design-tokens",
    "pretendard",
    "cobalt",
    "dark-mode",
    "atomic-design",
    "korean"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./components/index.js",
  "module": "./components/index.js",
  "exports": {
    ".": "./components/index.js",
    "./styles.css": "./styles.css",
    "./components": "./components/index.js",
    "./components/*": "./components/*",
    "./tokens/*": "./tokens/*",
    "./css/*": "./css/*"
  },
  "files": [
    "components",
    "tokens",
    "css",
    "assets/fonts",
    "styles.css",
    "README.md",
    "README.ko.md"
  ],
  "peerDependencies": {
    "react": ">=18"
  },
  "scripts": {
    "showcase": "echo \"No build step — open index.html in a browser, or run: npx serve .\""
  }
}
