{
  "$description": "Cobalt — color tokens, single source of truth (W3C Design Tokens format). Mirrors tokens/colors.css. Three layers: primitive ramps -> brand accent ramp (indirection) -> semantic (light/dark). Swap the accent ramp (or a [data-accent] preset) to re-brand; semantics re-derive and stay WCAG AA.",
  "$meta": { "system": "Cobalt — Mono Design System", "version": "0.2.0", "wcag": "AA" },

  "gray": {
    "$type": "color",
    "0":   { "$value": "#ffffff" }, "50":  { "$value": "#f7f8f9" }, "100": { "$value": "#eceef1" },
    "200": { "$value": "#dde0e5" }, "300": { "$value": "#c5cad1" }, "400": { "$value": "#9aa1ab" },
    "500": { "$value": "#6b727d" }, "600": { "$value": "#4d535d" }, "700": { "$value": "#363b43" },
    "800": { "$value": "#23272e" }, "900": { "$value": "#14171b" }, "950": { "$value": "#0d0f12" }
  },

  "cobalt": {
    "$type": "color",
    "50":  { "$value": "#eef2ff" }, "100": { "$value": "#dde5ff" }, "200": { "$value": "#bccbff" },
    "300": { "$value": "#93acff" }, "400": { "$value": "#5e84ff" }, "500": { "$value": "#2d5bff" },
    "600": { "$value": "#2447e0" }, "700": { "$value": "#1f3bb8" }, "800": { "$value": "#1c328f" },
    "900": { "$value": "#1a2d70" }
  },

  "status": {
    "$type": "color",
    "success": { "500": { "$value": "#0fa968" }, "600": { "$value": "#0c8a54" }, "700": { "$value": "#0a6e43" } },
    "warning": { "500": { "$value": "#d9870b" }, "600": { "$value": "#b56e08" }, "700": { "$value": "#875106" } },
    "danger":  { "500": { "$value": "#e0433a" }, "600": { "$value": "#c5352d" }, "700": { "$value": "#a62b24" } }
  },

  "accent": {
    "$type": "color",
    "$description": "Brand accent ramp — indirection layer. Default aliases the Cobalt ramp; a [data-accent] preset overrides these 10 steps to re-brand everything.",
    "50":  { "$value": "{cobalt.50}" }, "100": { "$value": "{cobalt.100}" }, "200": { "$value": "{cobalt.200}" },
    "300": { "$value": "{cobalt.300}" }, "400": { "$value": "{cobalt.400}" }, "500": { "$value": "{cobalt.500}" },
    "600": { "$value": "{cobalt.600}" }, "700": { "$value": "{cobalt.700}" }, "800": { "$value": "{cobalt.800}" },
    "900": { "$value": "{cobalt.900}" }
  },

  "semantic": {
    "$type": "color",
    "light": {
      "text":    { "primary": { "$value": "{gray.900}" }, "secondary": { "$value": "{gray.600}" }, "tertiary": { "$value": "{gray.500}" }, "link": { "$value": "{accent.600}" }, "accent": { "$value": "{accent.600}" } },
      "surface": { "page": { "$value": "{gray.50}" }, "card": { "$value": "{gray.0}" }, "sunken": { "$value": "{gray.100}" }, "accentSubtle": { "$value": "color-mix(in srgb, {accent.500} 8%, {gray.0})" } },
      "border":  { "default": { "$value": "{gray.200}" }, "strong": { "$value": "{gray.300}" }, "control": { "$value": "#868d97" }, "accent": { "$value": "{accent.500}" } },
      "accent":  { "base": { "$value": "{accent.500}", "$description": "decorative — focus ring, signature mark, fills" }, "solid": { "$value": "{accent.600}", "$description": "text/icon sits on it; white-on >=4.5" }, "solidHover": { "$value": "{accent.700}" }, "onAccent": { "$value": "{gray.0}" }, "focusRing": { "$value": "{accent.500}" } }
    },
    "dark": {
      "text":    { "primary": { "$value": "#f3f4f6" }, "secondary": { "$value": "#9aa1ab" }, "tertiary": { "$value": "#868d97" }, "link": { "$value": "{accent.300}" }, "accent": { "$value": "{accent.300}" } },
      "surface": { "page": { "$value": "#0d0f12" }, "card": { "$value": "#16181d" }, "sunken": { "$value": "#1d2025" }, "accentSubtle": { "$value": "color-mix(in srgb, {accent.400} 20%, #16181d)" } },
      "border":  { "default": { "$value": "#262a30" }, "strong": { "$value": "#343943" }, "control": { "$value": "#5e6571" }, "accent": { "$value": "{accent.400}" } },
      "accent":  { "base": { "$value": "{accent.400}" }, "solid": { "$value": "{accent.400}" }, "solidHover": { "$value": "{accent.300}" }, "onAccent": { "$value": "#0d0f12" }, "focusRing": { "$value": "{accent.400}" } }
    }
  },

  "brandPresets": {
    "$type": "color",
    "$description": "Override the accent ramp via [data-accent]. Each preset is verified AA (white-on-600 light CTA, 600-on-page link).",
    "violet": { "50": "#f5f3ff", "100": "#ede9fe", "200": "#ddd6fe", "300": "#c4b5fd", "400": "#a78bfa", "500": "#8b5cf6", "600": "#7c3aed", "700": "#6d28d9", "800": "#5b21b6", "900": "#4c1d95" },
    "indigo": { "50": "#eef2ff", "100": "#e0e7ff", "200": "#c7d2fe", "300": "#a5b4fc", "400": "#818cf8", "500": "#6366f1", "600": "#4f46e5", "700": "#4338ca", "800": "#3730a3", "900": "#312e81" }
  }
}
