{
  "$description": "Cobalt — color tokens, single source of truth (W3C Design Tokens format). Mirrors tokens/colors.css. Two layers: primitive ramps (gray / cobalt / status) -> semantic (light/dark). Cobalt is the single signature accent; semantics stay WCAG AA.",
  "$meta": { "system": "Cobalt — Mono Design System", "version": "0.2.0", "wcag": "AA" },

  "gray": {
    "$type": "color",
    "0":   { "$value": "#ffffff" }, "50":  { "$value": "#f7f8f9" }, "100": { "$value": "#eceef1" },
    "200": { "$value": "#dde0e5" }, "300": { "$value": "#c5cad1" }, "400": { "$value": "#9aa1ab" },
    "500": { "$value": "#6b727d" }, "600": { "$value": "#4d535d" }, "700": { "$value": "#363b43" },
    "800": { "$value": "#23272e" }, "900": { "$value": "#14171b" }, "950": { "$value": "#0d0f12" }
  },

  "cobalt": {
    "$type": "color",
    "$description": "Signature accent ramp — the single brand color. Links, focus, selected/active, key highlights.",
    "50":  { "$value": "#eef2ff" }, "100": { "$value": "#dde5ff" }, "200": { "$value": "#bccbff" },
    "300": { "$value": "#93acff" }, "400": { "$value": "#5e84ff" }, "500": { "$value": "#2d5bff" },
    "600": { "$value": "#2447e0" }, "700": { "$value": "#1f3bb8" }, "800": { "$value": "#1c328f" },
    "900": { "$value": "#1a2d70" }
  },

  "status": {
    "$type": "color",
    "success": { "500": { "$value": "#0fa968" }, "600": { "$value": "#0c8a54" }, "700": { "$value": "#0a6e43" } },
    "warning": { "500": { "$value": "#d9870b" }, "600": { "$value": "#b56e08" }, "700": { "$value": "#875106" } },
    "danger":  { "500": { "$value": "#e0433a" }, "600": { "$value": "#c5352d" }, "700": { "$value": "#a62b24" } }
  },

  "semantic": {
    "$type": "color",
    "light": {
      "text":    { "primary": { "$value": "{gray.900}" }, "secondary": { "$value": "{gray.600}" }, "tertiary": { "$value": "{gray.500}" }, "link": { "$value": "{cobalt.600}" }, "accent": { "$value": "{cobalt.600}" } },
      "surface": { "page": { "$value": "{gray.50}" }, "card": { "$value": "{gray.0}" }, "sunken": { "$value": "{gray.100}" }, "accentSubtle": { "$value": "{cobalt.50}" } },
      "border":  { "default": { "$value": "{gray.200}" }, "strong": { "$value": "{gray.300}" }, "control": { "$value": "#868d97" }, "accent": { "$value": "{cobalt.500}" } },
      "accent":  { "base": { "$value": "{cobalt.500}", "$description": "decorative — focus ring, signature mark, fills" }, "solid": { "$value": "{cobalt.600}", "$description": "text/icon sits on it; white-on >=4.5" }, "solidHover": { "$value": "{cobalt.700}" }, "onAccent": { "$value": "{gray.0}" }, "focusRing": { "$value": "{cobalt.500}" } }
    },
    "dark": {
      "text":    { "primary": { "$value": "#f3f4f6" }, "secondary": { "$value": "#9aa1ab" }, "tertiary": { "$value": "#868d97" }, "link": { "$value": "{cobalt.300}" }, "accent": { "$value": "{cobalt.300}" } },
      "surface": { "page": { "$value": "#0d0f12" }, "card": { "$value": "#16181d" }, "sunken": { "$value": "#1d2025" }, "accentSubtle": { "$value": "color-mix(in srgb, {cobalt.400} 20%, #16181d)" } },
      "border":  { "default": { "$value": "#262a30" }, "strong": { "$value": "#343943" }, "control": { "$value": "#5e6571" }, "accent": { "$value": "{cobalt.400}" } },
      "accent":  { "base": { "$value": "{cobalt.400}" }, "solid": { "$value": "{cobalt.400}" }, "solidHover": { "$value": "{cobalt.300}" }, "onAccent": { "$value": "#0d0f12" }, "focusRing": { "$value": "{cobalt.400}" } }
    }
  }
}
